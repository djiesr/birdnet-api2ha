# BirdNET-Go API to Home Assistant - Configuration example
# Copy to config.yaml and adjust paths.

# Path to BirdNET-Go SQLite database (read-only). Leave empty and run: python configure.py
database_path: ""

# Optional: base directory for audio clips (for building audio_url)
clips_base_path: ""

# Optional: path to BirdNET-Go config.yaml (to show DB type and name in /api/birdnet-config)
birdnet_config_path: ""

# HTTP server
http_host: "0.0.0.0"
http_port: 8081

# Fuseau IANA pour /api/hourly (schéma v2). Priorité : cette clé, sinon la variable
# d'environnement TZ (Docker Compose). Vide = pas de zoneinfo sauf si TZ est un IANA valide.
# Exemple : America/Toronto — aligner sur BirdNET-Go / lieu des enregistrements.
timezone: ""

# CORS (pour la carte Lovelace qui fait des fetch depuis le navigateur)
# Mets ici l'URL exacte de ton Home Assistant.
# Exemples:
#  - "http://homeassistant.local:8123"
#  - "http://192.168.10.50:8123"
# Laisse vide pour désactiver CORS (valeur par défaut).
cors:
  allowed_origins: []

# MQTT bridge: publish each new detection to a topic for Home Assistant
mqtt:
  enabled: false
  host: "localhost"
  port: 1883
  username: ""
  password: ""
  topic: "birdnet_api2ha/detections"
  poll_interval_seconds: 10
